{
  "name": "quotecheck",
  "version": "1.0.0",
  "private": true,
  "description": "Transparent home repair job estimates powered by Cloudflare",
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "dev:worker": "cd apps/worker && npm run dev",
    "build": "pnpm --filter web build && pnpm --filter worker build",
    "test": "pnpm --filter estimator test",
    "test:watch": "pnpm --filter estimator test:watch",
    "deploy": "pnpm build && wrangler deploy",
    "db:push": "wrangler d1 migrations apply quotecheck",
    "db:seed": "node scripts/seed-db.js",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "typescript": "^5.4.5",
    "pnpm": "^9.1.0",
    "wrangler": "^3.31.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
