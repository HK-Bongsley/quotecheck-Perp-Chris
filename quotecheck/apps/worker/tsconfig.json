{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noEmit": true,
    "paths": {
      "@quotecheck/*": ["../../packages/*/"]
    },
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src", "routes", "migrations"],
  "exclude": ["node_modules", "dist"]
}
